@page
@model LoginModel
@{
    ViewData["Title"] = "Вход";
    Layout = null; 
}

<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - shkolo.</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background-color: #ffffff;
        }
        
        .login-left {
            background-color: #1e2235; 
            background-size: 70%;
            background-repeat: no-repeat;
            background-position: center;
        }

        .shkolo-logo {
            font-size: 2.5rem;
            font-weight: 800;
            color: #000;
            margin-bottom: 2rem;
            letter-spacing: -1px;
        }

        .shkolo-dot {
            color: #00d27a;
        }

        .form-control {
            border-radius: 8px;
            padding: 0.8rem 1rem;
            border: 1px solid #ced4da;
            background-color: #f8f9fa;
        }

        .form-control:focus {
            box-shadow: none;
            border-color: #005cfc;
            background-color: #ffffff;
        }

        .btn-login {
            background-color: #005cfc;
            border-color: #005cfc;
            border-radius: 8px;
            padding: 0.8rem 2rem;
            font-weight: 600;
            letter-spacing: 0.5px;
        }

        .btn-login:hover {
            background-color: #004bce;
        }

        .text-shkolo-muted {
            color: #8c98a4;
            font-size: 0.9rem;
        }
    </style>
</head>
<body>

    <div class="container-fluid vh-100 overflow-hidden">
        <div class="row h-100">
            
            <div class="col-lg-6 d-none d-lg-flex login-left align-items-center justify-content-center">
                <h1 class="text-white opacity-25 fw-bold" style="font-size: 5rem;">shkolo<span style="color:#00d27a;">.</span></h1>
            </div>
            
            <div class="col-lg-6 d-flex align-items-center justify-content-center px-4">
                <div class="w-100" style="max-width: 420px;">
                    
                    <div class="shkolo-logo">shkolo<span class="shkolo-dot">.</span></div>
                    
                    <h2 class="fw-bold mb-1" style="font-size: 1.75rem;">Добре дошли в Shkolo</h2>
                    <p class="text-shkolo-muted mb-4 pb-2">Повече от електронен дневник</p>
                    
                    <form id="account" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>
                        
                        <div class="mb-3">
                            <label asp-for="Input.Email" class="form-label fw-bold small text-dark">Телефон или Електронна поща</label>
                            <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="Въведете тук" />
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>
                        
                        <div class="mb-4">
                            <label asp-for="Input.Password" class="form-label fw-bold small text-dark">Парола</label>
                            <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="Въведете тук" />
                            <span asp-validation-for="Input.Password" class="text-danger small"></span>
                        </div>
                        
                        <div class="d-flex justify-content-between align-items-center mb-5">
                            <button id="login-submit" type="submit" class="btn btn-login text-white px-5">ВХОД</button>
                            <a id="forgot-password" asp-page="./ForgotPassword" class="text-decoration-none text-shkolo-muted fw-semibold">Забравена парола?</a>
                        </div>
                        
                        <div class="text-center mt-5 pt-3">
                            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-decoration-none fw-bold" style="color: #005cfc;">Регистрация</a>
                        </div>
                    </form>
                    
                </div>
            </div>
            
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>
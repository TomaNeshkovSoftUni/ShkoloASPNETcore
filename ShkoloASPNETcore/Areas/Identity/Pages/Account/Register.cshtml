@page
@model RegisterModel
@{
    Layout = null;
    ViewData["Title"] = "Регистрация";
}

<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Shkolo</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">

    <style>
        body {
            background-color: #5C97BD;
            font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: flex-start;
            margin: 0;
            padding: 20px 0;
        }

        .shkolo-logo-container {
            margin-top: 10vh;
            margin-bottom: 25px;
        }

            .shkolo-logo-container img {
                width: 200px;
                height: auto;
            }

        .login-box {
            width: 100%;
            max-width: 410px; /* Намалено с 10px */
            background: #7CABCA; /* Изцяло еднакъв цвят за кутията */
            padding: 10px;
            border-radius: 0px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.35);
        }

        .login-card {
            background: #7CABCA;
            border-radius: 0px;
            overflow: hidden;
        }

        .login-tabs {
            display: flex;
            background-color: #7CABCA;
        }

        .login-tab-item {
            flex: 1;
            text-align: center;
            padding: 14px 0;
            font-weight: bold;
            font-size: 0.9rem;
            text-transform: uppercase;
            text-decoration: none;
            letter-spacing: 0.5px;
            transition: none;
        }

            .login-tab-item.active {
                background-color: #7CABCA;
                color: #ffffff;
            }

            .login-tab-item.inactive {
                background-color: #5C97BD;
                color: #ffffff;
            }

            .login-tab-item:hover {
                background-color: #7CABCA;
                color: #ffffff;
            }

        .card-body-form {
            padding: 30px 25px;
        }

        .inner-addon {
            position: relative;
            margin-bottom: 15px;
        }

            .inner-addon i {
                position: absolute;
                padding: 12px 15px;
                color: #6c757d;
                font-size: 0.95rem;
                pointer-events: none;
            }

            .inner-addon input {
                padding-left: 42px !important;
                height: 44px;
                border: 1px solid #ccc;
                border-radius: 0px;
                font-size: 0.95rem;
            }

                .inner-addon input:focus {
                    border-color: #5C97BD;
                    box-shadow: none;
                }

        .btn-shkolo-teal {
            background-color: #4CB0A7;
            color: #ffffff;
            border: none;
            border-radius: 0px;
            height: 44px;
            font-weight: bold;
            font-size: 1rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            transition: none;
        }

            .btn-shkolo-teal:hover {
                background-color: #3f968e;
                color: #ffffff;
            }
    </style>
</head>
<body>

    <div class="shkolo-logo-container">
        <a href="https://app.shkolo.bg/">
            <img src="https://app.shkolo.bg/img/logo.png" alt="Shkolo Logo" />
        </a>
    </div>

    <div class="login-box">
        <div class="login-card">

            <div class="login-tabs">
                <a href="./Login" class="login-tab-item inactive">Вход</a>
                <a href="#" class="login-tab-item active">Регистрация</a>
            </div>

            <div class="card-body-form">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small fw-bold mb-3"></div>

                    <div class="inner-addon">
                        <i class="fa fa-envelope"></i>
                        <input asp-for="Input.Email" class="form-control" placeholder="Имейл адрес" />
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>

                    <div class="inner-addon">
                        <i class="fa fa-font"></i>
                        <input asp-for="Input.FirstName" class="form-control" placeholder="Име" />
                        <span asp-validation-for="Input.FirstName" class="text-danger small"></span>
                    </div>

                    <div class="inner-addon">
                        <i class="fa fa-italic"></i>
                        <input asp-for="Input.LastName" class="form-control" placeholder="Фамилия" />
                        <span asp-validation-for="Input.LastName" class="text-danger small"></span>
                    </div>

                    <div class="inner-addon">
                        <i class="fa fa-lock"></i>
                        <input asp-for="Input.Password" type="password" class="form-control" placeholder="Парола" />
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>

                    <div class="inner-addon mb-4">
                        <i class="fa fa-check-double"></i>
                        <input asp-for="Input.ConfirmPassword" type="password" class="form-control" placeholder="Потвърди парола" />
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <div>
                        <button type="submit" class="w-100 btn btn-shkolo-teal">Регистрирай се</button>
                    </div>
                </form>
            </div>

        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>
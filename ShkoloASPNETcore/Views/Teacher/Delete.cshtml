@model ShkoloASPNETcore.Infrastructure.Data.Models.Teacher

@{
    ViewData["Title"] = "Изтриване на Учител";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-danger shadow">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">⚠️ Потвърждение за изтриване</h4>
                </div>
                <div class="card-body p-4">
                    <p class="lead text-center">Сигурни ли сте, че искате да изтриете този учител от системата?</p>
                    <hr />

                    <div class="mb-3">
                        <strong>Име:</strong> <span class="fw-bold">@Model.FirstName @Model.LastName</span>
                    </div>
                    <div class="mb-3">
                        <strong>Отдел:</strong> @Model.Department
                    </div>

                    <form asp-action="Delete" class="mt-4">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary">Отказ</a>
                            <button type="submit" class="btn btn-danger fw-bold">Да, ИЗТРИЙ УЧИТЕЛЯ</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
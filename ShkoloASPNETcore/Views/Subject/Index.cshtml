@model IEnumerable<ShkoloASPNETcore.Infrastructure.Data.Models.Subject>
@{
    ViewData["Title"] = "Предмети";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-end mb-3 border-bottom border-dark pb-2">
        <h2 class="m-0 text-uppercase fw-bold">Предмети</h2>
        @if (User.IsInRole("Administrator"))
        {
            <a asp-action="Create" class="btn btn-dark">СЪЗДАЙ ПРЕДМЕТ</a>
        }
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>ИМЕ НА ПРЕДМЕТА</th>
                <th>ВОДЕЩ УЧИТЕЛ</th>
                <th style="width: 250px;">ДЕЙСТВИЯ</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="3" class="text-center p-3">Няма намерени предмети.</td>
                </tr>
            }
            @foreach (var item in Model)
            {
                <tr>
                    <td class="fw-bold text-dark">@item.Name</td>
                    <td>@item.Teacher?.FirstName @item.Teacher?.LastName</td>
                    <td>
                        <div class="d-flex gap-1">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-dark">ДЕТАЙЛИ</a>

                            @if (User.IsInRole("Administrator"))
                            {
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-dark">КОРИГИРАЙ</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">ИЗТРИЙ</a>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
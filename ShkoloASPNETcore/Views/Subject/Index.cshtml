@model IEnumerable<ShkoloASPNETcore.Infrastructure.Data.Models.Subject>
@{
    ViewData["Title"] = "Предмети";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-end mb-3 border-bottom border-dark pb-2">
        <h2 class="m-0 text-uppercase fw-bold">Предмети</h2>
        @if (User.IsInRole("Teacher") || User.IsInRole("Administrator"))
        {
            <a asp-action="Create" class="btn btn-dark">СЪЗДАЙ ПРЕДМЕТ</a>
        }
    </div>

    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>ИМЕ НА ПРЕДМЕТА</th>
                <th>ВОДЕЩ УЧИТЕЛ</th>
                @if (User.IsInRole("Teacher") || User.IsInRole("Administrator"))
                {
                    <th style="width: 120px;">ДЕЙСТВИЯ</th>
                }
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="@(User.IsInRole("Teacher") || User.IsInRole("Administrator") ? "3" : "2")" class="text-center p-3">Няма намерени предмети.</td>
                </tr>
            }
            @foreach (var item in Model)
            {
                <tr>
                    <td class="fw-bold text-dark">@item.Name</td>
                    <td>@item.Teacher?.FirstName @item.Teacher?.LastName</td>
                    @if (User.IsInRole("Teacher") || User.IsInRole("Administrator"))
                    {
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-dark w-100">КОРИГИРАЙ</a>
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
</div>
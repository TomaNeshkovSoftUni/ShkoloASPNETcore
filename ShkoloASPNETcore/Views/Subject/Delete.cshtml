@model ShkoloASPNETcore.Infrastructure.Data.Models.Subject

@{
    ViewData["Title"] = "Изтрий Предмет";
}

<div class="container mt-4">
    <h2 class="text-uppercase fw-bold text-danger border-bottom border-dark pb-2 mb-4">Премахване на Предмет</h2>

    <div class="card p-4 shadow-sm border-danger" style="max-width: 600px;">
        <h4 class="text-danger fw-bold mb-3">Сигурни ли сте, че искате да изтриете този предмет?</h4>
        <p class="text-muted small">Внимание: Това действие може да изтрие и свързаните с предмета оценки!</p>

        <dl class="row mb-0">
            <dt class="col-sm-4 fw-bold text-muted">Предмет:</dt>
            <dd class="col-sm-8 fw-bold text-dark">@Model.Name</dd>

            <dt class="col-sm-4 fw-bold text-muted">Учител:</dt>
            <dd class="col-sm-8">@Model.Teacher?.FirstName @Model.Teacher?.LastName</dd>
        </dl>

        <form asp-action="Delete" class="d-flex gap-2 mt-4 border-top border-dark pt-3">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger px-4 fw-bold">ПОТВЪРДИ ИЗТРИВАНЕ</button>
            <a asp-action="Index" class="btn btn-outline-dark px-4 fw-bold">ОТКАЗ</a>
        </form>
    </div>
</div>
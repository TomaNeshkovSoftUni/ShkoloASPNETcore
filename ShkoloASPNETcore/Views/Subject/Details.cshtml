@model ShkoloASPNETcore.Infrastructure.Data.Models.Subject

@{
    ViewData["Title"] = "Детайли за Предмет";
}

<div class="container mt-4">
    <h2 class="text-uppercase fw-bold border-bottom border-dark pb-2 mb-4">Детайли за Предмет</h2>

    <div class="card p-4 shadow-sm" style="max-width: 600px;">
        <dl class="row mb-0">
            <dt class="col-sm-4 fw-bold text-muted">Име на предмета:</dt>
            <dd class="col-sm-8 fw-bold text-dark">@Model.Name</dd>

            <dt class="col-sm-4 fw-bold text-muted">Водещ учител:</dt>
            <dd class="col-sm-8">@Model.Teacher?.FirstName @Model.Teacher?.LastName</dd>
        </dl>

        <div class="d-flex gap-2 mt-4 border-top border-dark pt-3">
            @if (User.IsInRole("Teacher") || User.IsInRole("Administrator"))
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-dark px-4 fw-bold">КОРИГИРАЙ</a>
            }
            <a asp-action="Index" class="btn btn-outline-dark px-4 fw-bold">ОТКАЗ</a>
        </div>
    </div>
</div>
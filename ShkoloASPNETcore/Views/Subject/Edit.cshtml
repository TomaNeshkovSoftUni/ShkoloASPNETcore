@model ShkoloASPNETcore.Web.Models.SubjectFormViewModel

@{
    ViewData["Title"] = "Редактирай Предмет";
}

<div class="container mt-4">
    <h2>Редактирай Предмет</h2>
    <hr />
    <div class="row">
        <div class="col-md-4">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="Id" />

                <div class="form-group mb-3">
                    <label asp-for="Name" class="control-label fw-bold"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="TeacherId" class="control-label fw-bold"></label>
                    <select asp-for="TeacherId" class="form-control" asp-items="ViewBag.Teachers">
                        <option value="">-- Избери Учител --</option>
                    </select>
                    <span asp-validation-for="TeacherId" class="text-danger"></span>
                </div>

                <div class="form-group mt-4">
                    <input type="submit" value="ЗАПАЗИ" class="btn btn-dark" />
                    <a asp-action="Index" class="btn btn-outline-dark ms-2">ОТКАЗ</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
@model ShkoloASPNETcore.Infrastructure.Data.Models.Subject
@{
    ViewData["Title"] = "Добави Предмет";
}

<div class="container mt-4">
    <h2 class="text-uppercase fw-bold border-bottom border-dark pb-2 mb-4">Добавяне на Предмет</h2>

    <div class="card p-4 shadow-sm" style="max-width: 600px;">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold"></div>

            <div class="mb-4">
                <label asp-for="Name" class="form-label fw-bold">Име на Предмета</label>
                <input asp-for="Name" class="form-control border-dark" placeholder="напр. Математика, БЕЛ, История..." />
                <span asp-validation-for="Name" class="text-danger fw-bold small"></span>
            </div>

            <div class="d-flex gap-2 mt-2 border-top border-dark pt-3">
                <button type="submit" class="btn btn-dark px-4 fw-bold">ЗАПАЗИ</button>
                <a asp-action="Index" class="btn btn-outline-dark px-4 fw-bold">ОТКАЗ</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
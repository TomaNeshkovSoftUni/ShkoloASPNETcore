@model ShkoloASPNETcore.Web.Models.SubjectFormViewModel

@{
    ViewData["Title"] = "Добави Предмет";
}

<style>
    .bare-bones * {
        font-family: Arial, sans-serif !important;
        font-weight: normal !important;
        border-radius: 0 !important;
        box-shadow: none !important;
    }

    .header-blue {
        color: #3979B2;
        font-size: 24px;
        border-bottom: 2px solid #3979B2;
        padding-bottom: 10px;
        margin-bottom: 20px;
        margin-top: 0;
    }

    .card-custom {
        border: 1px solid #ccc;
        padding: 20px;
        max-width: 600px;
    }

    .form-control {
        border: 1px solid #ccc;
        padding: 8px;
        width: 100%;
        margin-bottom: 5px;
        box-sizing: border-box;
    }

    .control-label {
        color: #3979B2;
        display: block;
        margin-bottom: 5px;
    }

    .btn-save {
        background-color: #3979B2;
        color: white;
        border: none;
        padding: 8px 15px;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
    }

    .btn-cancel {
        background-color: #eee;
        color: #333;
        border: 1px solid #ccc;
        padding: 8px 15px;
        text-decoration: none;
        display: inline-block;
    }

    .text-danger {
        color: #E7505A !important;
        font-size: 14px;
    }
</style>

<div class="container mt-4 bare-bones">
    <h2 class="header-blue"><i class="fas fa-book-open"></i> Добави Предмет</h2>

    <div class="card-custom">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div style="margin-bottom: 15px;">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div style="margin-bottom: 20px;">
                <label asp-for="TeacherId" class="control-label"></label>
                <select asp-for="TeacherId" class="form-control" asp-items="ViewBag.Teachers">
                    <option value="">-- Избери Учител --</option>
                </select>
                <span asp-validation-for="TeacherId" class="text-danger"></span>
            </div>

            <div style="border-top: 1px solid #ccc; padding-top: 15px; display: flex; gap: 10px;">
                <button type="submit" class="btn-save"><i class="fas fa-plus"></i> СЪЗДАЙ</button>
                <a asp-action="Index" class="btn-cancel"><i class="fas fa-arrow-left"></i> ОТКАЗ</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
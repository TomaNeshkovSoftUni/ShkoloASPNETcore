@model ShkoloASPNETcore.Infrastructure.Data.Models.Student

@{
    ViewData["Title"] = "Изтриване на ученик";
}

<div class="container mt-4">
    <div class="card border-danger shadow-sm">
        <div class="card-header bg-danger text-white">
            <h4 class="mb-0">Потвърждение за изтриване</h4>
        </div>
        <div class="card-body">
            <h5>Сигурни ли сте, че искате да изтриете този запис?</h5>
            <hr />
            <dl class="row">
                <dt class="col-sm-2">Ученик</dt>
                <dd class="col-sm-10">@Model.FirstName @Model.LastName</dd>
            </dl>

            <form asp-action="DeleteConfirmed" asp-route-id="@Model.Id" method="post">
                <button type="submit" class="btn btn-danger">Да, изтрий</button>
                <a asp-action="Index" class="btn btn-secondary">Отказ</a>
            </form>
        </div>
    </div>
</div>
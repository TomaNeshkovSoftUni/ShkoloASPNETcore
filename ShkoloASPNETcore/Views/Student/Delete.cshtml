@model ShkoloASPNETcore.Infrastructure.Data.Models.Student

@{
    ViewData["Title"] = "Delete Student";
}

<div class="container mt-4">
    <div class="alert alert-danger shadow-sm">
        <h3 class="mb-2"><i class="bi bi-exclamation-triangle"></i> Warning!</h3>
        <p class="mb-0">Are you absolutely sure you want to remove this record? This action cannot be undone.</p>
    </div>

    <div class="card p-4 shadow-sm bg-light mt-3">
        <h4>Student Details</h4>
        <hr />
        <dl class="row">
            <dt class="col-sm-3 text-secondary">
                Internal Database ID
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.Id)
            </dd>
            <dt class="col-sm-3 text-secondary">
                Enrollment Number
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.EnrollmentNumber)
            </dd>
        </dl>

        <form asp-action="Delete" class="mt-3">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger me-2">Confirm Delete</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel and Go Back</a>
        </form>
    </div>
</div>
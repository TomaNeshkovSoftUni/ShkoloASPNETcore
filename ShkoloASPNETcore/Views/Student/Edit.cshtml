@model ShkoloASPNETcore.Infrastructure.Data.Models.Student

@{
    ViewData["Title"] = "Edit Student";
}

<div class="container mt-4">
    <h2>Edit Student Settings</h2>
    <hr />
    <div class="row">
        <div class="col-md-6 card p-4 shadow-sm bg-light">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="ApplicationUserId" />

                <div class="form-group mb-3">
                    <label asp-for="EnrollmentNumber" class="form-label font-weight-bold">Enrollment Reference</label>
                    <input asp-for="EnrollmentNumber" class="form-control" readonly />
                    <small class="text-muted">Enrollment numbers cannot be altered after creation.</small>
                </div>

                <div class="form-group mt-4">
                    <button type="submit" class="btn btn-primary me-2">Save Changes</button>
                    <a asp-action="Index" class="btn btn-secondary">Back to Dashboard</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
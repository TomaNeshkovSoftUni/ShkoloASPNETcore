@model ShkoloASPNETcore.Infrastructure.Data.Models.Student
@{
    ViewData["Title"] = "Редакция";
}

<div class="container mt-4">
    <h2 class="text-uppercase fw-bold border-bottom border-dark pb-2 mb-4">Редакция на Ученик</h2>

    <div class="card p-4" style="max-width: 600px;">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label asp-for="FirstName" class="form-label fw-bold">Име</label>
                <input asp-for="FirstName" class="form-control" />
                <span asp-validation-for="FirstName" class="text-danger fw-bold small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="LastName" class="form-label fw-bold">Фамилия</label>
                <input asp-for="LastName" class="form-control" />
                <span asp-validation-for="LastName" class="text-danger fw-bold small"></span>
            </div>

            <div class="d-flex gap-2 border-top border-dark pt-3">
                <button type="submit" class="btn btn-dark px-4">ОБНОВИ</button>
                <a asp-action="Index" class="btn btn-outline-dark px-4">ОТКАЗ</a>
            </div>
        </form>
    </div>
</div>
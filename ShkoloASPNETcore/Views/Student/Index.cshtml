@model IEnumerable<ShkoloASPNETcore.Infrastructure.Data.Models.Student>
@{
    ViewData["Title"] = "Ученици";
}

<style>
    .bare-bones * {
        font-family: Arial, sans-serif !important;
        font-weight: normal !important;
        border-radius: 0 !important;
        box-shadow: none !important;
        text-transform: none !important;
    }

    .header-container {
        border-bottom: 2px solid #3979B2;
        padding-bottom: 10px;
        margin-bottom: 20px;
    }

    .header-blue {
        color: #3979B2;
        font-size: 24px;
        margin: 0;
    }

    .alert-success-custom {
        background-color: #3979B2;
        color: white;
        padding: 10px;
        margin-bottom: 15px;
        border: 1px solid #2b5c8a;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 15px;
    }

    th, td {
        border: 1px solid #ddd;
        padding: 8px;
        text-align: left;
    }

    th {
        background-color: #3979B2;
        color: white;
    }

    .btn-info {
        background-color: #C49F47;
        color: white;
        border: none;
        padding: 5px 10px;
        text-decoration: none;
        display: inline-block;
    }

    .btn-delete {
        background-color: #E7505A;
        color: white;
        border: none;
        padding: 5px 10px;
        text-decoration: none;
        display: inline-block;
    }
</style>

<div class="container mt-4 bare-bones">
    <div class="header-container">
        <h2 class="header-blue"><i class="fas fa-users"></i> Списък на Учениците</h2>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert-success-custom">
            <i class="fas fa-check"></i> @TempData["SuccessMessage"]
        </div>
    }

    <table>
        <thead>
            <tr>
                <th>ИМЕ</th>
                <th>ФАМИЛИЯ</th>
                <th>ID В СИСТЕМАТА</th>
                <th style="text-align: center;">ДЕЙСТВИЯ</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="4" style="text-align: center; padding: 15px; color: #666;">Няма регистрирани ученици в системата.</td>
                </tr>
            }
            @foreach (var item in Model)
            {
                <tr>
                    <td style="color: #3979B2;">@item.FirstName</td>
                    <td style="color: #3979B2;">@item.LastName</td>
                    <td>@item.Id</td>
                    <td style="text-align: center;">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn-info"><i class="fas fa-info-circle"></i> Детайли</a>
                        @if (User.IsInRole("Administrator"))
                        {
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn-delete"><i class="fas fa-trash"></i> Изтрий</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
@model IEnumerable<ShkoloASPNETcore.Infrastructure.Data.Models.Grade>
@{
    ViewData["Title"] = "Оценки";
}

<style>
    .bare-bones * {
        font-family: Arial, sans-serif !important;
        font-weight: normal !important;
        border-radius: 0 !important;
        box-shadow: none !important;
        text-transform: none !important;
    }

    .header-container {
        border-bottom: 2px solid #3979B2;
        padding-bottom: 10px;
        margin-bottom: 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .header-blue {
        color: #3979B2;
        font-size: 24px;
        margin: 0;
    }

    .btn-add {
        background-color: #3979B2;
        color: white;
        border: none;
        padding: 8px 15px;
        text-decoration: none;
        display: inline-block;
    }

    .btn-delete {
        background-color: #E7505A;
        color: white;
        border: none;
        padding: 5px 10px;
        text-decoration: none;
        display: block;
        text-align: center;
        width: 100%;
        box-sizing: border-box;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 15px;
    }

    th, td {
        border: 1px solid #ddd;
        padding: 8px;
        text-align: left;
    }

    th {
        background-color: #3979B2;
        color: white;
    }
</style>

<div class="container mt-4 bare-bones">
    <div class="header-container">
        <h2 class="header-blue">Оценки</h2>
        @if (User.IsInRole("Teacher") || User.IsInRole("Administrator"))
        {
            <a asp-action="Create" class="btn-add">ДОБАВИ ОЦЕНКА</a>
        }
    </div>

    <table>
        <thead>
            <tr>
                <th>УЧЕНИК</th>
                <th>ПРЕДМЕТ</th>
                <th>УЧИТЕЛ</th>
                <th>СТОЙНОСТ</th>
                <th>ДАТА</th>
                @if (User.IsInRole("Teacher") || User.IsInRole("Administrator"))
                {
                    <th style="width: 120px; text-align: center;">ДЕЙСТВИЯ</th>
                }
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="@(User.IsInRole("Teacher") || User.IsInRole("Administrator") ? "6" : "5")" style="text-align: center; padding: 15px; color: #666;">Няма намерени оценки.</td>
                </tr>
            }
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Student?.FirstName @item.Student?.LastName</td>
                    <td>@item.Subject?.Name</td>
                    <td>@item.Issuer</td>
                    <td style="color: #3979B2;">@item.Value</td>
                    <td>@item.DateIssued.ToString("dd.MM.yyyy")</td>
                    @if (User.IsInRole("Teacher") || User.IsInRole("Administrator"))
                    {
                        <td>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn-delete">ИЗТРИЙ</a>
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
</div>
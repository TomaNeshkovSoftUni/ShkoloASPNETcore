@model IEnumerable<ShkoloASPNETcore.Infrastructure.Data.Models.Grade>
@{
    ViewData["Title"] = "Оценки";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-end mb-3 border-bottom border-dark pb-2">
        <h2 class="m-0 text-uppercase fw-bold">Оценки</h2>
        @if (User.IsInRole("Teacher") || User.IsInRole("Administrator"))
        {
            <a asp-action="Create" class="btn btn-dark">ДОБАВИ ОЦЕНКА</a>
        }
    </div>

    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>УЧЕНИК</th>
                <th>ПРЕДМЕТ</th>
                <th>УЧИТЕЛ</th>
                <th>СТОЙНОСТ</th>
                <th>ДАТА</th>
                @if (User.IsInRole("Teacher") || User.IsInRole("Administrator"))
                {
                    <th style="width: 120px;">ДЕЙСТВИЯ</th>
                }
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="@(User.IsInRole("Teacher") || User.IsInRole("Administrator") ? "6" : "5")" class="text-center p-3">Няма намерени оценки.</td>
                </tr>
            }
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Student?.FirstName @item.Student?.LastName</td>
                    <td>@item.Subject?.Name</td>
                    <td>@item.Subject?.Teacher?.FirstName @item.Subject?.Teacher?.LastName</td>
                    <td class="fw-bold text-dark">@item.Value</td>
                    <td>@item.DateIssued.ToString("dd.MM.yyyy")</td>
                    @if (User.IsInRole("Teacher") || User.IsInRole("Administrator"))
                    {
                        <td>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger w-100">ИЗТРИЙ</a>
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
</div>
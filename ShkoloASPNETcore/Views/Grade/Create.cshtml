@model ShkoloASPNETcore.Infrastructure.Data.Models.Grade
@{
    ViewData["Title"] = "Добави Оценка";
}

<div class="container mt-4">
    <h2 class="text-uppercase fw-bold border-bottom border-dark pb-2 mb-4">Добавяне на Оценка</h2>

    <div class="card p-4 shadow-sm" style="max-width: 600px;">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold"></div>

            <div class="mb-3">
                <label asp-for="StudentId" class="form-label fw-bold">Ученик</label>
                <select asp-for="StudentId" class="form-select" asp-items="ViewBag.Students">
                    <option value="">-- Избери Ученик --</option>
                </select>
                <span asp-validation-for="StudentId" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="SubjectId" class="form-label fw-bold">Предмет</label>
                <select asp-for="SubjectId" class="form-select" asp-items="ViewBag.Subjects">
                    <option value="">-- Избери Предмет --</option>
                </select>
                <span asp-validation-for="SubjectId" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Value" class="form-label fw-bold">Оценка</label>
                <input asp-for="Value" class="form-control border-dark" type="text" placeholder="напр. 5.50 или 6" />
                <span asp-validation-for="Value" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2 mt-2 border-top border-dark pt-3">
                <button type="submit" class="btn btn-dark px-4 fw-bold">ЗАПАЗИ</button>
                <a asp-action="Index" class="btn btn-outline-dark px-4 fw-bold">ОТКАЗ</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
@model ShkoloASPNETcore.Infrastructure.Data.Models.Grade

@{
    ViewData["Title"] = "Детайли за Оценка";
}

<div class="container mt-4">
    <h2 class="text-uppercase fw-bold border-bottom border-dark pb-2 mb-4">Детайли за Оценка</h2>

    <div class="card p-4 shadow-sm" style="max-width: 600px;">
        <dl class="row mb-0">
            <dt class="col-sm-4 fw-bold text-muted">Ученик:</dt>
            <dd class="col-sm-8">@Model.Student?.FirstName @Model.Student?.LastName</dd>

            <dt class="col-sm-4 fw-bold text-muted">Предмет:</dt>
            <dd class="col-sm-8">@Model.Subject?.Name</dd>

            <dt class="col-sm-4 fw-bold text-muted">Оценка:</dt>
            <dd class="col-sm-8 fw-bold text-dark">@Model.Value</dd>

            <dt class="col-sm-4 fw-bold text-muted">Въведена от:</dt>
            <dd class="col-sm-8">@Model.Issuer</dd>

            <dt class="col-sm-4 fw-bold text-muted">Дата:</dt>
            <dd class="col-sm-8">@Model.DateIssued.ToString("dd.MM.yyyy HH:mm")</dd>
        </dl>

        <div class="d-flex gap-2 mt-4 border-top border-dark pt-3">
            @if (User.IsInRole("Teacher") || User.IsInRole("Administrator"))
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-dark px-4 fw-bold">КОРИГИРАЙ</a>
            }
            <a asp-action="Index" class="btn btn-outline-dark px-4 fw-bold">ОТКАЗ</a>
        </div>
    </div>
</div>
@model ShkoloASPNETcore.Infrastructure.Data.Models.Grade

@{
    ViewData["Title"] = "Детайли за Оценка";
}

<style>
    .bare-bones * {
        font-family: Arial, sans-serif !important;
        font-weight: normal !important;
        border-radius: 0 !important;
        box-shadow: none !important;
    }

    .header-blue {
        color: #3979B2;
        font-size: 24px;
        border-bottom: 2px solid #3979B2;
        padding-bottom: 10px;
        margin-bottom: 20px;
        margin-top: 0;
    }

    .card-custom {
        border: 1px solid #ccc;
        padding: 20px;
        max-width: 600px;
    }

    .info-row {
        margin-bottom: 10px;
        display: flex;
    }

    .info-label {
        color: #666;
        width: 120px;
        display: inline-block;
    }

    .info-value {
        color: #333;
    }

    .btn-edit {
        background-color: #C49F47;
        color: white;
        border: none;
        padding: 8px 15px;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
    }

    .btn-cancel {
        background-color: #eee;
        color: #333;
        border: 1px solid #ccc;
        padding: 8px 15px;
        text-decoration: none;
        display: inline-block;
    }
</style>

<div class="container mt-4 bare-bones">
    <h2 class="header-blue">Детайли за Оценка</h2>

    <div class="card-custom">
        <div class="info-row">
            <span class="info-label">Ученик:</span>
            <span class="info-value">@Model.Student?.FirstName @Model.Student?.LastName</span>
        </div>
        <div class="info-row">
            <span class="info-label">Предмет:</span>
            <span class="info-value">@Model.Subject?.Name</span>
        </div>
        <div class="info-row">
            <span class="info-label">Оценка:</span>
            <span class="info-value" style="color: #3979B2;">@Model.Value</span>
        </div>
        <div class="info-row">
            <span class="info-label">Въведена от:</span>
            <span class="info-value">@Model.Issuer</span>
        </div>
        <div class="info-row">
            <span class="info-label">Дата:</span>
            <span class="info-value">@Model.DateIssued.ToString("dd.MM.yyyy HH:mm")</span>
        </div>

        <div style="margin-top: 20px; border-top: 1px solid #ccc; padding-top: 15px; display: flex; gap: 10px;">
            @if (User.IsInRole("Teacher") || User.IsInRole("Administrator"))
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-edit">КОРИГИРАЙ</a>
            }
            <a asp-action="Index" class="btn-cancel">ОТКАЗ</a>
        </div>
    </div>
</div>
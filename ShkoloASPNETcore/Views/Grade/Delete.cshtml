@model ShkoloASPNETcore.Infrastructure.Data.Models.Grade
@{
    ViewData["Title"] = "Изтриване";
}

<div class="container mt-4">
    <div class="alert alert-danger bg-white border-dark text-dark fw-bold mb-4 rounded-0" role="alert">
        СИГУРНИ ЛИ СТЕ, ЧЕ ИСКАТЕ ДА ИЗТРИЕТЕ ТОЗИ ЗАПИС? ТОВА ДЕЙСТВИЕ Е НЕОБРАТИМО.
    </div>

    <div class="card p-4" style="max-width: 600px;">
        <dl class="row mb-0">
            <dt class="col-sm-4">Стойност:</dt>
            <dd class="col-sm-8 fw-bold text-danger">@Model.Value</dd>

            <dt class="col-sm-4">Дата:</dt>
            <dd class="col-sm-8">@Model.DateIssued.ToString("dd.MM.yyyy")</dd>

            <dt class="col-sm-4">Предмет:</dt>
            <dd class="col-sm-8">@Model.Subject?.Name</dd>
        </dl>

        <form asp-action="Delete" method="post" class="mt-4 border-top border-dark pt-3 d-flex gap-2">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger px-4">ПОТВЪРДИ ИЗТРИВАНЕТО</button>
            <a asp-action="Index" class="btn btn-outline-dark px-4">ОТКАЗ</a>
        </form>
    </div>
</div>
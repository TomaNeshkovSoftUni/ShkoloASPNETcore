<style>
    .logout-btn {
        background: none;
        border: none;
        color: #ffffff;
        font-size: 1rem;
        cursor: pointer;
        width: 34px;
        height: 34px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        opacity: 0.5;
        transition: none !important;
    }

        .logout-btn:hover {
            background-color: #3979B2 !important;
            opacity: 1;
        }

        .logout-btn i {
            transition: none !important;
        }

    .nav-user-section {
        display: flex;
        align-items: center;
    }
</style>

<div class="nav-user-section">
    <span class="text-white small me-3">
        @User.Identity?.Name
    </span>

    <form asp-area="Identity"
          asp-page="/Account/Logout"
          asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })"
          class="d-inline">

        <button type="submit" class="logout-btn" title="Изход">
            <i class="fas fa-sign-out-alt"></i>
        </button>
    </form>
</div>
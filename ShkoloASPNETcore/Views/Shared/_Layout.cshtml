<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SHKOLO</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        :root {
            --shkolo-blue: #1b4366;
            --shkolo-light-blue: #538cb3;
            --shkolo-bg: #eef2f5;
            --shkolo-teal: #40bca6;
            --shkolo-orange: #e65a4b;
        }

        body {
            background-color: var(--shkolo-bg);
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            margin: 0;
            padding: 0;
            height: 100vh;
        }

        .guest-body {
            background-color: var(--shkolo-light-blue);
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
        }

        .shkolo-login-card {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(10px);
            border-radius: 4px;
            width: 420px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.15);
            border: none;
        }

        .shkolo-tabs {
            display: flex;
            border-bottom: 1px solid rgba(0,0,0,0.08);
        }

        .shkolo-tab {
            flex: 1;
            text-align: center;
            padding: 15px;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 14px;
            color: #777;
            text-decoration: none;
            cursor: pointer;
        }

            .shkolo-tab.active {
                background: #ffffff;
                color: var(--shkolo-blue);
                border-top-left-radius: 4px;
            }

            .shkolo-tab:not(.active) {
                background: rgba(255,255,255,0.4);
            }

        .shkolo-input-group {
            position: relative;
            margin-bottom: 15px;
        }

            .shkolo-input-group i {
                position: absolute;
                left: 12px;
                top: 50%;
                transform: translateY(-50%);
                color: #888;
            }

        .shkolo-input {
            width: 100%;
            padding: 12px 12px 12px 40px;
            border: 1px solid #ccc;
            border-radius: 2px;
            font-size: 14px;
            outline: none;
        }

        .shkolo-btn-teal {
            background-color: var(--shkolo-teal);
            color: white;
            width: 100%;
            padding: 12px;
            border: none;
            font-weight: bold;
            text-transform: uppercase;
            border-radius: 2px;
            font-size: 14px;
            letter-spacing: 0.5px;
        }

            .shkolo-btn-teal:hover {
                background-color: #35a38f;
                color: white;
            }

        .shkolo-topbar {
            background-color: var(--shkolo-blue);
            height: 50px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 20px;
            color: white;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1030;
        }

        .shkolo-sidebar {
            width: 240px;
            background-color: var(--shkolo-blue);
            position: fixed;
            top: 50px;
            bottom: 0;
            left: 0;
            z-index: 1000;
            padding-top: 10px;
            overflow-y: auto;
        }

            .shkolo-sidebar .nav-link {
                color: #c2d1db;
                padding: 12px 20px;
                font-size: 14px;
                display: flex;
                align-items: center;
                gap: 12px;
                border-left: 4px solid transparent;
            }

                .shkolo-sidebar .nav-link:hover {
                    background-color: rgba(255,255,255,0.05);
                    color: white;
                }

            .shkolo-sidebar .nav-item.active .nav-link {
                background-color: var(--shkolo-orange);
                color: white;
                border-left: 4px solid #fff;
            }

        .shkolo-content-wrapper {
            margin-left: 240px;
            padding: 75px 25px 25px 25px;
            min-height: 100vh;
        }

        .shkolo-error-block {
            border-radius: 4px;
            font-size: 14px;
            display: none;
        }

            .shkolo-error-block ul {
                margin-left: 15px;
            }

            .shkolo-error-block li {
                margin-bottom: 5px;
            }
    </style>
</head>
<body class="@(User.Identity?.IsAuthenticated == true ? "" : "guest-body")">

    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="shkolo-topbar">
            <div class="d-flex align-items-center gap-3">
                <span class="fw-bold tracking-wider" style="letter-spacing: 1px;">SHKOLO</span>
                <small class="text-white-50 d-none d-md-inline">| Дневник</small>
            </div>
            <div class="d-flex align-items-center gap-3">
                <i class="bi bi-bell position-relative fs-5" style="cursor: pointer;">
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-circle bg-danger" style="font-size: 9px; padding: 3px 6px;">4</span>
                </i>
                <i class="bi bi-envelope fs-5" style="cursor: pointer;"></i>
                <div class="d-flex align-items-center gap-2 border-start ps-3">
                    <i class="bi bi-person-circle fs-5"></i>
                    <span class="small d-none d-sm-inline">@User.Identity.Name</span>
                    <form class="d-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                        <button type="submit" class="btn btn-link text-white p-0 ms-2" style="text-decoration: none;"><i class="bi bi-box-arrow-right"></i></button>
                    </form>
                </div>
            </div>
        </div>

        <div class="shkolo-sidebar">
            <ul class="nav flex-column h-100">
                <li class="nav-item active">
                    <a class="nav-link" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-house-door-fill"></i> Начало
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Student" asp-action="Index">
                        <i class="bi bi-people-fill"></i> Ученици
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Grade" asp-action="Index">
                        <i class="bi bi-journal-bookmark-fill"></i> Оценки
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Absence" asp-action="Index">
                        <i class="bi bi-exclamation-triangle-fill"></i> Отсъствия
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Remark" asp-action="Index">
                        <i class="bi bi-chat-left-text-fill"></i> Забележки
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Subject" asp-action="Index">
                        <i class="bi bi-book-half"></i> Предмети
                    </a>
                </li>
                @if (User.IsInRole("Administrator"))
                {
                    <li class="nav-item">
                        <a class="nav-link text-warning" asp-controller="Teacher" asp-action="Index">
                            <i class="bi bi-shield-lock-fill"></i> Учители (Админ)
                        </a>
                    </li>
                }

                <li class="mt-auto nav-item d-flex justify-content-center gap-3 p-3 text-white-50 small border-top" style="background-color: rgba(255,255,255,0.05);">
                    <i class="bi bi-facebook fs-6"></i>
                    <i class="bi bi-instagram fs-6"></i>
                    <i class="bi bi-youtube fs-6"></i>
                </li>
                <li class="nav-item d-flex justify-content-center gap-2 p-3 text-white-50 small border-top" style="background-color: rgba(255,255,255,0.05);">
                    <button class="btn btn-sm btn-outline-light rounded-1 px-3 py-1 small">
                        <i class="bi bi-google-play me-1"></i> Google Play
                    </button>
                    <button class="btn btn-sm btn-outline-light rounded-1 px-3 py-1 small">
                        <i class="bi bi-apple me-1"></i> App Store
                    </button>
                </li>
            </ul>
        </div>

        <div class="shkolo-content-wrapper">
            @RenderBody()
        </div>
    }
    else
    {
        <div class="d-none">
            @RenderBody()
        </div>

        <div class="text-center">
            <div class="mb-4 text-white fw-bold fs-3" style="letter-spacing: 3px;">SHKOLO</div>
            <div class="shkolo-login-card text-start">
                <div class="shkolo-tabs">
                    <div class="shkolo-tab active">Вход</div>
                    <div class="shkolo-tab">Регистрация</div>
                </div>
                <div class="p-4">
                    <form id="shkoloLoginForm" asp-area="Identity" asp-page="/Account/Login" method="post">

                        <div id="validationErrorBlock" class="shkolo-error-block mb-3 p-3 rounded-2 text-danger" style="background-color: #fcebeb; border: 1px solid #f8c2b5;">
                            <div class="fw-bold fs-6 mb-2">Грешка!</div>
                            <ul id="errorList" class="mb-0 small ps-3">
                            </ul>
                        </div>

                        <div class="shkolo-input-group">
                            <i class="bi bi-person"></i>
                            <input type="text" id="loginEmail" name="Input.Email" class="shkolo-input" placeholder="Имейл или потребителско име" />
                        </div>
                        <div class="shkolo-input-group">
                            <i class="bi bi-lock"></i>
                            <input type="password" id="loginPassword" name="Input.Password" class="shkolo-input" placeholder="Парола" />
                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-4 small">
                            <label class="text-muted" style="cursor: pointer;">
                                <input type="checkbox" name="Input.RememberMe" class="me-1" /> Запомни ме
                            </label>
                            <a href="#" class="text-decoration-none text-secondary">Забравена парола</a>
                        </div>
                        <button type="submit" class="shkolo-btn-teal mb-3">Вход</button>
                    </form>

                    <div class="text-center my-3 text-muted position-relative">
                        <hr class="m-0" />
                        <span class="position-absolute top-50 start-50 translate-middle bg-white px-2 small text-uppercase" style="font-size: 11px;">Или</span>
                    </div>

                    <div class="d-flex justify-content-center gap-2 mt-3">
                        <button class="btn btn-outline-secondary rounded-1 px-3 py-2"><i class="bi bi-microsoft text-danger"></i></button>
                        <button class="btn btn-outline-secondary rounded-1 px-3 py-2"><i class="bi bi-facebook text-primary"></i></button>
                        <button class="btn btn-outline-secondary rounded-1 px-3 py-2"><i class="bi bi-google text-success"></i></button>
                        <button class="btn btn-outline-secondary rounded-1 px-3 py-2"><i class="bi bi-book text-warning"></i></button>
                    </div>
                </div>
            </div>
            <div class="mt-4 text-white-50 small">
                При технически проблеми: <a href="mailto:support@shkolo.com" class="text-white text-decoration-none">support@shkolo.com</a>
            </div>
        </div>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>


    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const form = document.getElementById("shkoloLoginForm");
            if (form) {
                form.addEventListener("submit", function (e) {
                    const emailInput = document.getElementById("loginEmail").value.trim();
                    const passwordInput = document.getElementById("loginPassword").value.trim();

                    const errorBlock = document.getElementById("validationErrorBlock");
                    const errorList = document.getElementById("errorList");

                    let errors = [];

                    if (!emailInput) {
                        errors.push("Полето Потребителско име е задължително.");
                    }
                    if (!passwordInput) {
                        errors.push("Полето Парола е задължително.");
                    }

                    if (errors.length > 0) {
                        e.preventDefault(); 

                        errorList.innerHTML = "";

                        errors.forEach(function (errorText) {
                            const li = document.createElement("li");
                            li.textContent = errorText;
                            errorList.appendChild(li);
                        });

                        // Add your fun easter egg list item
                        const funLi = document.createElement("li");
                        funLi.innerHTML = 'При забравена парола натиснете <a href="#" class="text-danger fw-bold text-decoration-none">ТУК</a> .';
                        errorList.appendChild(funLi);

                        errorBlock.style.display = "block"; 
                    }
                });
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
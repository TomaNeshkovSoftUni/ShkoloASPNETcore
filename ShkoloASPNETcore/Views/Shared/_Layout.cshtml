<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Shkolo</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ShkoloASPNETcore.styles.css" asp-append-version="true" />

    <style>
        * {
            box-sizing: border-box;
        }

        html, body {
            height: 100%;
            margin: 0;
            padding: 0;
        }

        body {
            background-color: #eef0f5;
            font-family: Arial, sans-serif;
            font-size: 14px;
        }

        .app-shell {
            display: flex;
            height: 100vh;
            overflow: hidden;
        }

        /* ── Sidebar ── */
        .shkolo-sidebar {
            width: 235px;
            min-width: 235px;
            background-color: #4276A4;
            display: flex;
            flex-direction: column;
            overflow-y: auto;
            z-index: 100;
        }

        .sidebar-brand {
            height: 50px;
            padding: 0 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: #2D5F8B;
        }

        .brand-logo-img {
            width: 169px;
            height: auto;
        }

        .sidebar-brand-name {
            color: #ffffff;
            font-size: 1.2rem;
            font-weight: 700;
            line-height: 1.2;
        }

        .shkolo-nav-link {
            color: #a8b8cc;
            padding: 12px 20px;
            display: flex;
            align-items: center;
            gap: 12px;
            text-decoration: none;
            font-size: 0.875rem;
            font-weight: 500;
            border-left: 4px solid transparent;
            border-bottom: 1px solid #4A83B6;
            white-space: nowrap;
        }

            .shkolo-nav-link:hover {
                color: #ffffff;
                background-color: #497FAE;
            }
            .shkolo-nav-link.active-menu {
                color: #ffffff;
                background-color: #D64635;
            }

            .shkolo-nav-link i {
                font-size: 1rem;
                width: 18px;
                text-align: center;
            }

        .sidebar-footer {
            padding: 12px 16px;
            color: #4e657e;
            font-size: 0.7rem;
            border-top: 1px solid #3a6288;
            text-align: center;
            margin-top: auto;
        }

        .main-panel {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            min-width: 0;
        }

        .shkolo-topbar {
            background-color: #2D5F8B;
            height: 50px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 20px;
        }

        .main-content {
            flex: 1;
            overflow-y: auto;
            padding: 22px 24px;
            background-color: #eef0f5;
        }

        .content-card {
            background-color: #ffffff;
            border-radius: 8px;
            box-shadow: 0 1px 4px rgba(0,0,0,0.07);
            padding: 24px;
        }

        .shkolo-footer {
            background-color: #234668;
            color: #4e657e;
            font-size: 0.72rem;
            padding: 10px 20px;
            display: flex;
            justify-content: space-between;
        }
    </style>
</head>
<body>

    <div class="app-shell">
        <aside class="shkolo-sidebar">
            <a class="sidebar-brand" asp-controller="Home" asp-action="Index">
                <img src="https://app.shkolo.bg/img/bg/shkolo_classbook_logo.svg" alt="Shkolo" class="brand-logo-img" />
            </a>

            <nav class="flex-grow-1 py-2">
                @* global *@
                <a class="shkolo-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active-menu" : "")"
                   asp-controller="Home" asp-action="Index">
                    <i class="fa fa-home"></i> Начало
                </a>

                @* admin/teacher only *@
                @if (!User.IsInRole("Student"))
                {
                    <a class="shkolo-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Student" ? "active-menu" : "")"
                       asp-controller="Student" asp-action="Index">
                        <i class="fa fa-running"></i> Ученици
                    </a>

                    <a class="shkolo-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Teacher" ? "active-menu" : "")"
                       asp-controller="Teacher" asp-action="Index">
                        <i class="fa fa-graduation-cap"></i> Учители
                    </a>

                    <a class="shkolo-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Subject" ? "active-menu" : "")"
                       asp-controller="Subject" asp-action="Index">
                        <i class="fa fa-book"></i> Предмети
                    </a>
                }

                @* students only *@
                <a class="shkolo-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Grade" ? "active-menu" : "")"
                   asp-controller="Grade" asp-action="Index">
                    <i class="fa fa-chart-line"></i> Оценки
                </a>

                <a class="shkolo-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Absence" ? "active-menu" : "")"
                   asp-controller="Absence" asp-action="Index">
                    <i class="fa-solid fa-address-book"></i> Отсъствия
                </a>

                <a class="shkolo-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Remark" ? "active-menu" : "")"
                   asp-controller="Remark" asp-action="Index">
                    <i class="fa fa-spell-check"></i> Забележки
                </a>
            </nav>
        </aside>

        <div class="main-panel">
            <header class="shkolo-topbar">
                <div class="text-white fw-bold">SHKOLO Платформа</div>
                <div class="topbar-right">
                    <partial name="_LoginPartial" />
                </div>
            </header>

            <main class="main-content">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                <div class="content-card">
                    @RenderBody()
                </div>
            </main>

            <footer class="shkolo-footer">
                <div>&copy; 2026 – SHKOLO Платформа</div>
                <a asp-controller="Home" asp-action="Privacy" class="text-decoration-none">Поверителност</a>
            </footer>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
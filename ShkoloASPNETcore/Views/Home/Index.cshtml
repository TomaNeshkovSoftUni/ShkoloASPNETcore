@model ShkoloASPNETcore.Web.Models.DashboardViewModel

<style>
    .dashboard-card {
        border: 0;
        border-radius: 0;
        overflow: hidden;
        min-height: 140px;
        height: 100%;
    }

        .dashboard-card .card-body {
            padding: 1.5rem;
        }

    .dashboard-value {
        font-size: 2.2rem;
        line-height: 1;
        margin: 0;
    }

    .dashboard-label {
        font-size: .8rem;
        letter-spacing: 1px;
        text-transform: uppercase;
        opacity: .95;
    }

    .dashboard-icon {
        font-size: 2.5rem;
        opacity: .3;
    }

    .bg-grade {
        background-color: #3598DC;
    }

    .bg-grades {
        background-color: #32C5D2;
    }

    .bg-absence {
        background-color: #E7505A;
    }

    .bg-feedback {
        background-color: #C49F47;
    }

    .ranking-card {
        border: 1px solid #ddd;
        border-radius: 0;
    }

    .ranking-value {
        font-size: 3rem;
        color: #659BE0;
    }

    /* Custom Flex layout for exact gaps and positioning */
    .shkolo-cards-container {
        display: flex;
        flex-wrap: wrap;
        gap: 27px;
        position: relative;
        left: -100px;
    }

    .shkolo-card-wrapper {
        flex: 1 1 0;
        min-width: 200px;
    }

    /* AJAX stats layout box matching your left-shifted grid alignment */
    .shkolo-ajax-box {
        position: relative;
        left: -100px;
        margin-top: 40px;
    }

    .ajax-pill {
        background-color: #f1f3fa;
        color: #333;
        padding: 10px 18px;
        border-left: 4px solid #659BE0;
        font-size: 13px;
    }

    @@media (max-width: 991px) {
        .shkolo-cards-container, .shkolo-ajax-box {
            left: 0;
        }
    }
</style>

<div class="container-fluid px-0" style="font-family: Arial, sans-serif;">

    <div class="text-white py-2 mb-4 text-center" style="background-color:#659BE0;">
        <div class="container">
            <i class="fa-solid fa-graduation-cap"></i>
            <span>@Model.FullName.ToUpper()</span>
        </div>
    </div>

    <div class="container">

        <div class="shkolo-cards-container mb-4">
            <div class="shkolo-card-wrapper">
                <a href="/Grade" class="text-decoration-none">
                    <div class="card dashboard-card text-white bg-grade">
                        <div class="card-body d-flex flex-column justify-content-between">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h2 class="dashboard-value">@Model.Value.ToString("F2")</h2>
                                <i class="fa-solid fa-chart-line dashboard-icon"></i>
                            </div>
                            <div class="dashboard-label">@(Model.IsStaff ? "Успех на училището" : "Успех")</div>
                        </div>
                    </div>
                </a>
            </div>

            <div class="shkolo-card-wrapper">
                <a href="/Grade" class="text-decoration-none">
                    <div class="card dashboard-card text-white bg-grades">
                        <div class="card-body d-flex flex-column justify-content-between">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h2 class="dashboard-value">@Model.GradesCount</h2>
                                <i class="fas fa-pencil-alt dashboard-icon"></i>
                            </div>
                            <div class="dashboard-label">Оценки</div>
                        </div>
                    </div>
                </a>
            </div>

            <div class="shkolo-card-wrapper">
                <a href="/Absence" class="text-decoration-none">
                    <div class="card dashboard-card text-white bg-absence">
                        <div class="card-body d-flex flex-column justify-content-between">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h2 class="dashboard-value">@Model.AbsencesCount.ToString("G29")</h2>
                                <i class="fas fa-exclamation-circle dashboard-icon"></i>
                            </div>
                            <div class="dashboard-label">Отсъствия</div>
                        </div>
                    </div>
                </a>
            </div>

            <div class="shkolo-card-wrapper">
                <a href="/Remark" class="text-decoration-none">
                    <div class="card dashboard-card text-white bg-feedback">
                        <div class="card-body d-flex flex-column justify-content-between">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h2 class="dashboard-value">@Model.FeedbackCount</h2>
                                <i class="fa-solid fa-certificate dashboard-icon"></i>
                            </div>
                            <div class="dashboard-label">Отзиви</div>
                        </div>
                    </div>
                </a>
            </div>
        </div>

        @if (!Model.IsStaff)
        {
            <div class="card ranking-card p-4">
                <h5 class="text-secondary mb-4">
                    <i class="fa-solid fa-chart-line"></i> КЛАСАЦИЯ
                </h5>
                <div class="text-center">
                    <div class="ranking-value">@Model.SchoolRank</div>
                    <p class="text-muted small text-uppercase mb-0">място в училище</p>
                </div>
            </div>
        }

        @if (!User.IsInRole("Student"))
        {
            <div class="shkolo-ajax-box">
                <h5 class="text-secondary mb-3" style="font-size: .85rem; letter-spacing: 0.5px;">
                    <i class="fa-solid fa-network-wired me-1"></i> GLOBAL LIVE SYSTEM STATISTICS
                </h5>
                <div class="d-flex gap-3">
                    <div class="ajax-pill">
                        Total Students Enrolled: <span id="ajax-student-count">...</span>
                    </div>
                    <div class="ajax-pill">
                        Total Active Teacher Accounts: <span id="ajax-teacher-count">...</span>
                    </div>
                </div>
            </div>
        }

    </div>
</div>

@section Scripts {
    @if (!User.IsInRole("Student"))
    {
        <script>
            $(document).ready(function () {
                $.ajax({
                    url: '/api/statistics',
                    type: 'GET',
                    dataType: 'json',
                    success: function (data) {
                        $('#ajax-student-count').text(data.students);
                        $('#ajax-teacher-count').text(data.teachers);
                    },
                    error: function () {
                        $('#ajax-student-count').text("Error");
                        $('#ajax-teacher-count').text("Error");
                    }
                });
            });
        </script>
    }
}
@{
    ViewData["Title"] = "Начало";
}

<div class="container mt-5">
    <div class="p-5 border border-dark" style="background-color: #fcfcfc;">
        <h1 class="text-uppercase fw-bold border-bottom border-dark pb-3 mb-4" style="letter-spacing: -1px;">
            Добре дошли в Shkolo.
        </h1>

        <p class="fs-5 mb-4 text-dark">
            Вие сте влезли успешно в системата. Моля, използвайте навигационното меню, за да достъпите вашите данни.
        </p>

        <div class="row g-0">
            @if (User.IsInRole("Teacher") || User.IsInRole("Administrator"))
            {
                <div class="col-md-6 border border-dark p-3 bg-dark text-white fw-bold text-center">
                    РЕЖИМ: УЧИТЕЛ / АДМИНИСТРАТОР
                </div>
                <div class="col-md-6 border border-dark border-start-0 p-3 text-center">
                    ПЪЛЕН ДОСТЪП ДО ОЦЕНКИ И ЗАБЕЛЕЖКИ
                </div>
            }
            else
            {
                <div class="col-md-6 border border-dark p-3 text-center fw-bold">
                    РЕЖИМ: УЧЕНИК
                </div>
                <div class="col-md-6 border border-dark border-start-0 p-3 text-center text-muted">
                    ДОСТЪП САМО ДО ЛИЧНИ ДАННИ
                </div>
            }
        </div>
    </div>
</div>
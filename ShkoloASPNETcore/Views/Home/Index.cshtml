@model ShkoloASPNETcore.Web.Models.DashboardViewModel

<div class="container-fluid px-0">
    <div class="text-white py-3 mb-4 text-center" style="background-color: #659BE0;">
        <div class="container">
            <i class="fa-solid fa-graduation-cap"></i> <strong>@Model.FullName.ToUpper()</strong>
        </div>
    </div>

    <div class="container">
        <div class="row g-2 mb-4">
            <div class="col-md-2">
                <a href="/Grade" class="text-decoration-none">
                    <div class="card text-white border-0" style="background-color: #3598DC; border-radius: 0;">
                        <div class="card-body p-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <h2 class="fw-bold mb-0">@Model.Value.ToString("F2")</h2>
                                <i class="fa-solid fa-chart-line fa-2x opacity-50"></i>
                            </div>
                            <small class="text-uppercase fw-bold">@(Model.IsStaff ? "Успех на училището" : "Успех")</small>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col-md-2">
                <a href="/Grade" class="text-decoration-none">
                    <div class="card text-white border-0" style="background-color: #32C5D2; border-radius: 0;">
                        <div class="card-body p-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <h2 class="fw-bold mb-0">@Model.GradesCount</h2>
                                <i class="fas fa-pencil-alt fa-2x opacity-50"></i>
                            </div>
                            <small class="text-uppercase fw-bold">Оценки</small>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col-md-2">
                <a href="/Absence" class="text-decoration-none">
                    <div class="card text-white border-0" style="background-color: #E7505A; border-radius: 0;">
                        <div class="card-body p-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <h2 class="fw-bold mb-0">@Model.AbsencesCount.ToString("G29")</h2>
                                <i class="fas fa-exclamation-circle fa-2x opacity-50"></i>
                            </div>
                            <small class="text-uppercase fw-bold">Отсъствия</small>
                        </div>
                    </div>
                </a>
            </div>

            <div class="col-md-2">
                <a href="/Remark" class="text-decoration-none">
                    <div class="card text-white border-0" style="background-color: #C49F47; border-radius: 0;">
                        <div class="card-body p-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <h2 class="fw-bold mb-0">@Model.FeedbackCount</h2>
                                <i class="fa-solid fa-certificate fa-2x opacity-50"></i>
                            </div>
                            <small class="text-uppercase fw-bold">Отзиви</small>
                        </div>
                    </div>
                </a>
            </div>
        </div>

        @if (!Model.IsStaff)
        {
            <div class="card border p-4 shadow-sm" style="border-radius: 0;">
                <h5 class="fw-bold text-secondary mb-4"><i class="fa-solid fa-chart-line"></i> КЛАСАЦИЯ</h5>
                <div class="text-center">
                    <h2 class="fw-bold">@Model.SchoolRank</h2>
                    <p class="text-muted small text-uppercase">място в училище</p>
                </div>
            </div>
        }
    </div>
</div>
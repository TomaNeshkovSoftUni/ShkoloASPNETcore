@using ShkoloASPNETcore.Infrastructure.Data.Enums
@model IEnumerable<ShkoloASPNETcore.Infrastructure.Data.Models.Remark>
@{
    ViewData["Title"] = "Забележки и Похвали";
}

<style>
    .bare-bones * {
        font-family: Arial, sans-serif !important;
        font-weight: normal !important;
        border-radius: 0 !important;
        box-shadow: none !important;
        text-transform: none !important;
    }

    .shkolo-header {
        background-color: #3979B2;
        color: white;
        padding: 10px;
    }

    .btn-shkolo {
        background-color: #3979B2;
        color: white;
        border: none;
        padding: 5px 15px;
        text-decoration: none;
        display: inline-block;
    }

        .btn-shkolo:hover {
            color: white;
            background-color: #2b5c8a;
        }

    .btn-edit {
        background-color: #C49F47;
        color: white;
        border: none;
        padding: 5px 10px;
        text-decoration: none;
    }

    .btn-delete {
        background-color: #E7505A;
        color: white;
        border: none;
        padding: 5px 10px;
        text-decoration: none;
    }

    .badge-praise {
        background-color: #C49F47;
        color: white;
        padding: 5px;
        display: inline-block;
    }

    .badge-penalty {
        background-color: #E7505A;
        color: white;
        padding: 5px;
        display: inline-block;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 15px;
    }

    th, td {
        border: 1px solid #ddd;
        padding: 8px;
        text-align: left;
    }

    th {
        background-color: #3979B2;
        color: white;
    }
</style>

<div class="container mt-4 bare-bones">
    <div class="d-flex justify-content-between align-items-center mb-3" style="border-bottom: 2px solid #3979B2; padding-bottom: 10px;">
        <h2 style="margin: 0; font-size: 24px; color: #3979B2;">Дневник на отзивите</h2>
        @if (User.IsInRole("Teacher") || User.IsInRole("Administrator"))
        {
            <a asp-action="Create" class="btn-shkolo">ДОБАВИ ОТЗИВ</a>
        }
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div style="background-color: #C49F47; color: white; padding: 10px; margin-bottom: 15px;">
            @TempData["SuccessMessage"]
        </div>
    }

    <table>
        <thead>
            <tr>
                <th>УЧЕНИК</th>
                <th>ПРЕДМЕТ</th>
                <th>ТИП</th>
                <th>ПРОЯВА / КОМЕНТАР</th>
                <th>ВЪВЕОД ХОРА (УЧИТЕЛ)</th>
                <th>ДАТА</th>
                @if (User.IsInRole("Teacher") || User.IsInRole("Administrator"))
                {
                    <th style="text-align: center;">ДЕЙСТВИЯ</th>
                }
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="7" style="text-align: center; padding: 15px; color: #666;">Няма намерени забележки или похвали.</td>
                </tr>
            }
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Student?.FirstName @item.Student?.LastName</td>
                    <td>@item.Subject?.Name</td>
                    <td>
                        @if (item.Type == RemarkType.Похвала)
                        {
                            <span class="badge-praise">Похвала</span>
                        }
                        else
                        {
                            <span class="badge-penalty">Забележка</span>
                        }
                    </td>
                    <td>
                        <div style="color: #3979B2;">@item.Label</div>
                        @if (!string.IsNullOrEmpty(item.Comment))
                        {
                            <div style="color: #666; font-size: 12px; margin-top: 5px;">Коментар: @item.Comment</div>
                        }
                    </td>
                    <td>@item.Issuer</td>
                    <td>@item.DateIssued.ToString("dd.MM.yyyy")</td>
                    @if (User.IsInRole("Teacher") || User.IsInRole("Administrator"))
                    {
                        <td style="text-align: center;">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn-edit">Редакция</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn-delete">Изтрий</a>
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
</div>
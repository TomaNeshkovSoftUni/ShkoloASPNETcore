@model IEnumerable<ShkoloASPNETcore.Infrastructure.Data.Models.Remark>

@{
    ViewData["Title"] = "Дневник на класа - Забележки";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-journal-text text-primary"></i> Забележки и Похвали</h2>
        <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Добави запис</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Ученик ID</th>
                        <th>Предмет</th>
                        <th>Тип</th>
                        <th>Съдържание</th>
                        <th>Дата</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.StudentId</td>
                            <td>@item.Subject.Name</td>
                            <td>
                                @if (item.Type == ShkoloASPNETcore.Infrastructure.Data.Enums.RemarkType.Похвала)
                                {
                                    <span class="badge bg-success">@item.Type</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">@item.Type</span>
                                }
                            </td>
                            <td>@item.Text</td>
                            <td>@item.DateIssued.ToString("dd.MM.yyyy HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
@using ShkoloASPNETcore.Infrastructure.Data.Enums
@model ShkoloASPNETcore.Web.Models.RemarkFormViewModel

@{
    ViewData["Title"] = "Редактиране на отзив";
}

<style>
    .bare-bones * {
        font-family: Arial, sans-serif !important;
        font-weight: normal !important;
        border-radius: 0 !important;
        box-shadow: none !important;
    }

    .form-control, .form-select {
        border: 1px solid #ccc;
        padding: 8px;
    }

    .card-header-gold {
        background-color: #3979B2;
        color: white;
        padding: 15px;
        font-size: 18px;
    }

    .btn-edit-save {
        background-color: #3979B2;
        color: white;
        border: none;
        padding: 8px 15px;
        cursor: pointer;
    }

    .btn-cancel {
        background-color: #eee;
        color: #333;
        border: 1px solid #ccc;
        padding: 8px 15px;
        text-decoration: none;
    }
</style>

<div class="container mt-4 bare-bones">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card" style="border: 1px solid #3979B2;">
                <div class="card-header-gold">
                    Редактиране на отзив
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="StudentId" />

                        <div class="mb-3">
                            <label class="form-label" style="color: #666;">Ученик (Не може да се променя)</label>
                            <select class="form-select" asp-items="ViewBag.Students" disabled="disabled" style="background-color: #f9f9f9;"></select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label" style="color: #3979B2;">Предмет</label>
                            <select asp-for="SubjectId" class="form-select" asp-items="ViewBag.Subjects"></select>
                            <span asp-validation-for="SubjectId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label" style="color: #3979B2;">Тип на отзива</label>
                            <select asp-for="Type" id="remarkTypeSelect" class="form-select" asp-items="Html.GetEnumSelectList<RemarkType>()"></select>
                            <span asp-validation-for="Type" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label" style="color: #3979B2;">Конкретна проява (Фраза)</label>
                            <select asp-for="SelectedText" id="selectedTextSelect" class="form-select">
                                <option value="@Model.SelectedText">@Model.SelectedText</option>
                            </select>
                            <span asp-validation-for="SelectedText" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label" style="color: #3979B2;">Допълнителен коментар</label>
                            <textarea asp-for="Comment" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Comment" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn-cancel">Отказ</a>
                            <button type="submit" class="btn-edit-save">Запази промените</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        const praises = @Json.Serialize(ShkoloASPNETcore.Web.Models.RemarkFormViewModel.Praises);
        const penalties = @Json.Serialize(ShkoloASPNETcore.Web.Models.RemarkFormViewModel.Penalties);
        const typeSelect = document.getElementById('remarkTypeSelect');
        const textSelect = document.getElementById('selectedTextSelect');
        const currentSavedText = "@Model.SelectedText";

        function updatePhrases() {
            const selectedType = typeSelect.value;
            textSelect.innerHTML = '';
            const listToUse = (selectedType == "0") ? praises : penalties;
            listToUse.forEach(phrase => {
                const option = document.createElement('option');
                option.value = phrase;
                option.textContent = phrase;
                if(phrase === currentSavedText) {
                    option.selected = true;
                }
                textSelect.appendChild(option);
            });
        }
        typeSelect.addEventListener('change', updatePhrases);
        document.addEventListener('DOMContentLoaded', updatePhrases);
    </script>
}
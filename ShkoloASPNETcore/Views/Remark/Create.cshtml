@using ShkoloASPNETcore.Infrastructure.Data.Enums
@model ShkoloASPNETcore.Infrastructure.Data.Models.Remark

@{
    ViewData["Title"] = "Въвеждане на забележка/похвала";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Нов отзив в дневника</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="form-group mb-3">
                            <label class="form-label font-weight-bold">Изберете ученик (ID)</label>
                            <select asp-for="StudentId" class="form-select" asp-items="ViewBag.Students"></select>
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label font-weight-bold">Предмет</label>
                            <select asp-for="SubjectId" class="form-select" asp-items="ViewBag.Subjects"></select>
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label font-weight-bold">Тип на отзива</label>
                            <select asp-for="Type" class="form-select" asp-items="Html.GetEnumSelectList<RemarkType>()"></select>
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label font-weight-bold">Текст / Описание</label>
                            <textarea asp-for="Text" class="form-control" rows="3" placeholder="Въведете коментар от учителя..."></textarea>
                            <span asp-validation-for="Text" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-secondary">Отказ</a>
                            <button type="submit" class="btn btn-success">Запиши в дневника</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
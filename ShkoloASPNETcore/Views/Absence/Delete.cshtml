@model ShkoloASPNETcore.Infrastructure.Data.Models.Absence

@{
    ViewData["Title"] = "Изтриване на запис";
}

<style>
    .bare-bones * {
        font-family: Arial, sans-serif !important;
        font-weight: normal !important;
        border-radius: 0 !important;
        box-shadow: none !important;
    }

    .alert-danger-custom {
        background-color: #fff;
        border: 1px solid #E7505A;
        color: #E7505A;
        padding: 15px;
        margin-bottom: 20px;
    }

    .card-custom {
        border: 1px solid #E7505A;
        padding: 20px;
        max-width: 600px;
    }

    .info-row {
        margin-bottom: 10px;
        display: flex;
    }

    .info-label {
        color: #333;
        width: 120px;
        display: inline-block;
    }

    .info-value {
        color: #333;
    }

    .val-danger {
        color: #E7505A;
    }

    .btn-delete {
        background-color: #E7505A;
        color: white;
        border: none;
        padding: 8px 15px;
        cursor: pointer;
        display: inline-block;
        text-decoration: none;
    }

    .btn-cancel {
        background-color: #eee;
        color: #333;
        border: 1px solid #ccc;
        padding: 8px 15px;
        text-decoration: none;
        display: inline-block;
    }
</style>

<div class="container mt-4 bare-bones">
    <div class="alert-danger-custom">
        <i class="fas fa-exclamation-triangle"></i> СИГУРНИ ЛИ СТЕ, ЧЕ ИСКАТЕ ДА ИЗТРИЕТЕ ТОЗИ ЗАПИС ОТ ДНЕВНИКА? ТОВА ДЕЙСТВИЕ Е НЕОБРАТИМО.
    </div>

    <div class="card-custom">
        <div class="info-row">
            <span class="info-label">Ученик:</span>
            <span class="info-value val-danger">@Model.Student?.FirstName @Model.Student?.LastName</span>
        </div>
        <div class="info-row">
            <span class="info-label">Предмет:</span>
            <span class="info-value">@Model.Subject?.Name</span>
        </div>
        <div class="info-row">
            <span class="info-label">Тип:</span>
            <span class="info-value">@Model.Type.ToString()</span>
        </div>
        <div class="info-row">
            <span class="info-label">Дата:</span>
            <span class="info-value">@Model.DateIssued.ToString("dd.MM.yyyy")</span>
        </div>

        <form asp-action="Delete" method="post" style="margin-top: 20px; border-top: 1px solid #eee; padding-top: 15px; display: flex; gap: 10px;">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn-delete"><i class="fas fa-trash"></i> ПОТВЪРДИ ИЗТРИВАНЕТО</button>
            <a asp-action="Index" class="btn-cancel"><i class="fas fa-arrow-left"></i> ОТКАЗ</a>
        </form>
    </div>
</div>
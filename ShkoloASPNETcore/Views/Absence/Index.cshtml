@model IEnumerable<ShkoloASPNETcore.Infrastructure.Data.Models.Absence>
@{
    ViewData["Title"] = "Отсъствия";
}

<style>
    .bare-bones * {
        font-family: Arial, sans-serif !important;
        font-weight: normal !important;
        border-radius: 0 !important;
        box-shadow: none !important;
        text-transform: none !important;
    }

    .header-container {
        border-bottom: 2px solid #3979B2;
        padding-bottom: 10px;
        margin-bottom: 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .header-blue {
        color: #3979B2;
        font-size: 24px;
        margin: 0;
    }

    .alert-success-custom {
        background-color: #3979B2;
        color: white;
        padding: 10px;
        margin-bottom: 15px;
        border: 1px solid #2b5c8a;
    }

    .alert-error-custom {
        background-color: #E7505A;
        color: white;
        padding: 10px;
        margin-bottom: 15px;
        border: 1px solid #c9303b;
    }

    .btn-add {
        background-color: #3979B2;
        color: white;
        border: none;
        padding: 8px 15px;
        text-decoration: none;
        display: inline-block;
    }

    .btn-edit {
        background-color: #C49F47;
        color: white;
        border: none;
        padding: 5px 10px;
        text-decoration: none;
        display: inline-block;
        margin-right: 5px;
    }

    .btn-delete {
        background-color: #E7505A;
        color: white;
        border: none;
        padding: 5px 10px;
        text-decoration: none;
        display: inline-block;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 15px;
    }

    th, td {
        border: 1px solid #ddd;
        padding: 8px;
        text-align: left;
    }

    th {
        background-color: #3979B2;
        color: white;
    }

    .badge-custom {
        padding: 3px 8px;
        color: white;
        display: inline-block;
        font-size: 12px;
    }

    .bg-absent {
        background-color: #E7505A;
    }

    .bg-late {
        background-color: #C49F47;
    }
</style>

<div class="container mt-4 bare-bones">
    <div class="header-container">
        <h2 class="header-blue"><i class="fas fa-clipboard-list"></i> Отсъствия</h2>
        @if (User.IsInRole("Teacher") || User.IsInRole("Administrator"))
        {
            <a asp-action="Create" class="btn-add"><i class="fas fa-plus"></i> ВЪВЕДИ ОТСЪСТВИЕ</a>
        }
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert-success-custom">
            <i class="fas fa-check"></i> @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert-error-custom">
            <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
        </div>
    }

    <table>
        <thead>
            <tr>
                <th>УЧЕНИК</th>
                <th>ПРЕДМЕТ</th>
                <th>УЧИТЕЛ</th>
                <th>ТИП</th>
                <th>ДАТА</th>
                @if (User.IsInRole("Teacher") || User.IsInRole("Administrator"))
                {
                    <th style="width: 220px; text-align: center;">ДЕЙСТВИЯ</th>
                }
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="@(User.IsInRole("Teacher") || User.IsInRole("Administrator") ? "6" : "5")" style="text-align: center; padding: 15px; color: #666;">Няма намерени отсъствия.</td>
                </tr>
            }
            @foreach (var item in Model)
            {
                <tr>
                    <td style="color: #3979B2;">@item.Student?.FirstName @item.Student?.LastName</td>
                    <td>@item.Subject?.Name</td>
                    <td>@item.Subject?.Teacher?.FirstName @item.Subject?.Teacher?.LastName</td>
                    <td>
                        <span class="badge-custom @(item.Type.ToString() == "Закъснение" ? "bg-late" : "bg-absent")">
                            @item.Type.ToString()
                        </span>
                    </td>
                    <td>@item.DateIssued.ToString("dd.MM.yyyy")</td>
                    @if (User.IsInRole("Teacher") || User.IsInRole("Administrator"))
                    {
                        <td style="text-align: center;">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn-edit"><i class="fas fa-edit"></i> КОРИГИРАЙ</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn-delete"><i class="fas fa-trash"></i> ИЗТРИЙ</a>
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
</div>
@using ShkoloASPNETcore.Infrastructure.Data.Enums
@model ShkoloASPNETcore.Infrastructure.Data.Models.Absence

@{
    ViewData["Title"] = "Въвеждане на отсъствие/закъснение";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0">Въвеждане в дневника</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="form-group mb-3">
                            <label class="form-label font-weight-bold">Изберете ученик (ID)</label>
                            <select asp-for="StudentId" class="form-select" asp-items="@(ViewBag.Students ?? new SelectList(Enumerable.Empty<SelectListItem>()))"></select>
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label font-weight-bold">Предмет</label>
                            <select asp-for="SubjectId" class="form-select" asp-items="@(ViewBag.Subjects ?? new SelectList(Enumerable.Empty<SelectListItem>()))"></select>
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label font-weight-bold">Тип на отсъствието</label>
                            <select asp-for="Type" class="form-select" asp-items="Html.GetEnumSelectList<AbsenceType>()"></select>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-secondary">Отказ</a>
                            <button type="submit" class="btn btn-warning text-dark">Добави отсъствие</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
@using ShkoloASPNETcore.Infrastructure.Data.Enums
@model ShkoloASPNETcore.Infrastructure.Data.Models.Absence

@{
    ViewData["Title"] = "Въвеждане на отсъствие/закъснение";
}

<style>
    .bare-bones * {
        font-family: Arial, sans-serif !important;
        font-weight: normal !important;
        border-radius: 0 !important;
        box-shadow: none !important;
    }

    .header-blue {
        color: #3979B2;
        font-size: 24px;
        border-bottom: 2px solid #3979B2;
        padding-bottom: 10px;
        margin-bottom: 20px;
        margin-top: 0;
    }

    .card-custom {
        border: 1px solid #ccc;
        padding: 20px;
        max-width: 600px;
    }

    .form-control, .form-select {
        border: 1px solid #ccc;
        padding: 8px;
        width: 100%;
        margin-bottom: 5px;
        box-sizing: border-box;
    }

    .form-label {
        color: #3979B2;
        display: block;
        margin-bottom: 5px;
    }

    .btn-save {
        background-color: #3979B2;
        color: white;
        border: none;
        padding: 8px 15px;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
    }

    .btn-cancel {
        background-color: #eee;
        color: #333;
        border: 1px solid #ccc;
        padding: 8px 15px;
        text-decoration: none;
        display: inline-block;
    }

    .text-danger {
        color: #E7505A !important;
        font-size: 14px;
    }
</style>

<div class="container mt-4 bare-bones">
    <h2 class="header-blue"><i class="fas fa-user-times"></i> Въвеждане в дневника</h2>

    <div class="card-custom">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3" style="margin-bottom: 15px;">
                <label class="form-label">Ученик</label>
                <select asp-for="StudentId" class="form-select" asp-items="@(ViewBag.Students ?? new SelectList(Enumerable.Empty<SelectListItem>()))"></select>
                <span asp-validation-for="StudentId" class="text-danger"></span>
            </div>

            <div class="mb-3" style="margin-bottom: 15px;">
                <label class="form-label">Предмет</label>
                <select asp-for="SubjectId" class="form-select" asp-items="@(ViewBag.Subjects ?? new SelectList(Enumerable.Empty<SelectListItem>()))"></select>
                <span asp-validation-for="SubjectId" class="text-danger"></span>
            </div>

            <div class="mb-4" style="margin-bottom: 20px;">
                <label class="form-label">Тип на записа</label>
                <select asp-for="Type" class="form-select" asp-items="Html.GetEnumSelectList<AbsenceType>()"></select>
                <span asp-validation-for="Type" class="text-danger"></span>
            </div>

            <div style="border-top: 1px solid #ccc; padding-top: 15px; display: flex; gap: 10px;">
                <button type="submit" class="btn-save"><i class="fas fa-save"></i> ЗАПИШИ</button>
                <a asp-action="Index" class="btn-cancel"><i class="fas fa-arrow-left"></i> ОТКАЗ</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
@{
    ViewData["Title"] = "Грешка 401";
}

<style>
    .bare-bones * {
        font-family: Arial, sans-serif !important;
        font-weight: normal !important;
        border-radius: 0 !important;
        box-shadow: none !important;
    }

    .error-container {
        border: 1px solid #C49F47;
        padding: 40px;
        max-width: 500px;
        margin: 50px auto;
        text-align: center;
    }

    .error-title {
        color: #C49F47;
        font-size: 36px;
        margin-top: 0;
        margin-bottom: 10px;
    }

    .error-subtitle {
        color: #333;
        font-size: 18px;
        margin-bottom: 15px;
    }

    .error-text {
        color: #666;
        margin-bottom: 25px;
        font-size: 14px;
    }

    .btn-back {
        background-color: #C49F47;
        color: white;
        border: none;
        padding: 10px 20px;
        text-decoration: none;
        display: inline-block;
    }
</style>

<div class="bare-bones">
    <div class="error-container">
        <h1 class="error-title"><i class="fas fa-lock"></i> Грешка 401</h1>
        <div class="error-subtitle">Нямате достъп до тази страница!</div>
        <div class="error-text">Тази секция изисква по-високи нива на достъп (Администратор/Учител).</div>
        <a asp-controller="Home" asp-action="Index" class="btn-back"><i class="fas fa-home"></i> Назад към таблото</a>
    </div>
</div>